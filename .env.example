DATABASE_URL="file:./dev.db"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
MERCADO_PAGO_ACCESS_TOKEN=""

# Armazenamento de fotos: local | cloudinary | supabase
# Sem configurar provedor externo, usa pasta public/uploads (desenvolvimento)
IMAGE_STORAGE_PROVIDER="local"

# Cloudinary (produção recomendado)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_PRESET=""
CLOUDINARY_FOLDER="nosso-momento"

# Supabase Storage (alternativa)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="photos"

# Carta com IA (opcional — sem chave, usa modelo local)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
